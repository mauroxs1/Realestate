# Meta / WhatsApp Cloud API
META_ACCESS_TOKEN=           # System User Permanent Access Token de Meta
PHONE_NUMBER_ID=             # ID del número de teléfono (Meta for Developers > Configuración API)
WABA_ID=                     # WhatsApp Business Account ID
WEBHOOK_VERIFY_TOKEN=        # Token que vos elegís para verificar el webhook (ej: lorenzo_propiedades_2025)

# Anthropic
ANTHROPIC_API_KEY=           # sk-ant-...
ANTHROPIC_BUDGET_USD=5       # Presupuesto cargado en Anthropic (para alertas)

# Upstash Redis
UPSTASH_REDIS_REST_URL=      # https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=    # Token de Upstash Redis

# Groq (transcripción de audio — gratis)
GROQ_API_KEY=                # gsk_...

# Google Sheets Web App (Apps Script)
SHEETS_WEBHOOK_URL=          # https://script.google.com/macros/s/XXXX/exec

# Notificaciones (formato internacional sin +, ej: 5492614001234)
# Ricardo recibe TODO: visitas agendadas, escaladas, consultas y resumen final de cierre
OWNER_PHONE=5492615017406

# Lorenzo Propiedades
WEBSITE_URL=                 # URL de la web de la inmobiliaria (ej: https://lorenzopropiedades.com.ar)
CIUDAD=                      # Ciudad donde opera la inmobiliaria (ej: Mendoza)

# Cron de actualización semanal
CRON_SECRET=                 # Token secreto para proteger el endpoint /api/refresh (inventalo vos, ej: "refresh_lorenzo_2025")
